              onModelChange={setSelectedModel}
            />
          }
        />
      </div>

      {/* Fixed Input */}
      <div className="sticky bottom-0 bg-white border-t border-gray-200 p-2">
        {/* If ChatInterface contains input already, move it here or style it sticky */}
      </div>
    </div>
  </div>
